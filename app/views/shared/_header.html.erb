<header class="header">
  <div class="header__inner">
    <h1 class="header__title header-title">
      <%= link_to new_post_path, class: "header-logo_link" do %>
        良いこと日記
      <% end %>
    </h1>

    <nav class="header__nav nav" id="js-nav">
      <ul class="nav__items nav-items">
        <li class="nav-items__item"><%= link_to 'みんなの記録', posts_path, class: "header-nav_link" %></li>
        <li class="nav-items__item"><%= link_to 'マイページ', my_posts_path, class: "header-nav_link" %></li>
        <li class="nav-items__item"><%= link_to '記録作成', new_post_path, class: "header-nav_link" %></li>
        <li class="nav-items__item">
          <%= button_to logout_path, method: :delete, class: "header-nav_link", data: { turbo: false } do %>ログアウト<% end %>
        </li>
      </ul>
    </nav>

    <button class="header__hamburger hamburger" id="js-hamburger">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>