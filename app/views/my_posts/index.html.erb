<div class="pt-3 mt-16">
  <div class="w-10/12 mx-auto">
    <h1 class="text-3xl font-bold text-center">自分の記録一覧</h1>
    
    <% if @posts.present? %>
      <div class="flex flex-col space-y-4 mt-12">
        <%= render @posts %>
      </div>
    <% else %>
      <div class="text-center text-gray-500 py-10">
        まだ投稿がありません。
      </div>
    <% end %>
  </div>
</div>