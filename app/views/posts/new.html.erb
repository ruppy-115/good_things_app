<div class="container">
  <div class="row">
    <div class="col-lg-8 offset-lg-2">
      <h1>記録作成</h1>
      <%= form_with model: @post, class: "new_board" do |f| %>
        <div class="mb-3">
          <%= f.label :body %>
          <%= f.text_area :body, class: "form-control", rows: "10" %>
        </div>
        <%= f.submit "投稿", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
</div>