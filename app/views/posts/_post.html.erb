<div class="w-full p-2 mb-4">
  <div id="post-id-<%= post.id %>" class="h-full">
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 h-full flex flex-col">
      
      <%# --- 記事本文 --- %>
      <div class="px-5 py-3 flex-grow">
        <div class="flex items-start">
          <p class="whitespace-pre-wrap text-gray-700 font-normal text-lg leading-relaxed"><%= post.body %></p>
        </div>
      </div>

      <%# --- 日付 --- %>
      <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 rounded-b-lg">
        <div class="flex items-center text-sm text-gray-500">
          <%= post.created_at.strftime('%-m月%-d日 %H:%M') %>
        </div>
      </div>
    </div>
  </div>
</div>