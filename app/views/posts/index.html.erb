<div class="my-16">
  <div class="w-10/12 mx-auto">
    <h1 class="text-3xl font-bold text-center">みんなの記録一覧</h1>
    <!-- 掲示板一覧 -->
    <% if @posts.present? %>
      <div class="flex flex-col mt-12">
        <%= render @posts %>
      </div>
    <% else %>
      <div class="mb-3">記録がありません</div>
    <% end %>
    <%= link_to '記録作成', new_post_path, class: "!no-underline w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-[#008db7] hover:bg-[#00769a] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer transition duration-150" %>
  </div>
</div>
