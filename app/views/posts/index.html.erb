<div class="min-h-screen bg-[#FDFBF7] pb-24">
  
  <%# --- ヘッダーエリア（緑色） --- %>
  <div class="bg-[#AED7BE] pt-4 shadow-sm z-10 relative">
    <div class="flex justify-center items-center mb-4">
      <div class="flex items-center space-x-2">
        <%# ここにロゴ画像を配置 %>
        <span class="text-gray-700 font-bold text-lg">プラス日記</span>
      </div>
    </div>

    <div class="flex justify-center w-full px-4">
      <div class="relative w-full max-w-md flex justify-between text-sm font-bold text-gray-700">
        <div class="flex-1 text-center pb-2 border-b-4 border-[#FDFBF7] cursor-pointer">
          世界の良いこと
        </div>
        <div class="flex-1 text-center pb-2 text-gray-500 cursor-pointer hover:text-gray-700">
          フレンドの良いこと
        </div>
      </div>
    </div>
  </div>

  <%# --- カレンダーエリア（クリーム色） --- %>
  <div class="bg-[#F2F0E9] py-3 shadow-inner">
    <div class="flex items-center justify-center space-x-1 px-2 overflow-x-auto whitespace-nowrap scrollbar-hide">
      <button class="text-gray-400 hover:text-gray-600 px-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <% (8..14).each_with_index do |day, i| %>
        <% active = i == 3 # 仮で11日をアクティブに %>
        <div class="flex flex-col items-center justify-center w-10 h-14 rounded-full flex-shrink-0 cursor-pointer <%= active ? 'text-[#AED7BE]' : 'text-gray-600' %>">
          <span class="text-xs font-bold mb-1"><%= %w(日 月 火 水 木 金 土)[i] %></span>
          <span class="text-lg font-bold <%= active ? 'scale-125 transition-transform' : '' %>"><%= day %></span>
          <% if active %>
            <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-b-[8px] border-b-[#AED7BE] mt-1"></div>
          <% end %>
        </div>
      <% end %>

      <button class="text-gray-400 hover:text-gray-600 px-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>

  <%# --- メインコンテンツ（ノート風） --- %>
  <div class="px-2 mt-4 max-w-lg mx-auto relative perspective-1000">
    <div id="notebook-page" class="bg-white rounded-r-lg shadow-lg min-h-[600px] flex relative notebook-grid origin-left transition-transform duration-500">
      
      <div class="w-12 flex-shrink-0 relative border-r border-gray-200">
        <div class="flex flex-col items-center space-y-6 pt-8 h-full">
          <%# リングの数だけループ %>
          <% 10.times do %>
            <div class="relative w-full flex justify-center">
              <div class="w-4 h-4 bg-gray-300 rounded-full shadow-inner"></div>
              <div class="absolute -left-3 top-1 w-8 h-2 bg-gray-400 rounded-full border border-gray-500 transform -rotate-12 shadow-md z-10"></div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="flex-grow p-4 pt-8">
        <% if @posts.present? %>
          <div class="flex flex-col space-y-4">
            <%= render @posts %>
          </div>
        <% else %>
          <div class="text-center text-gray-400 mt-10">記録がありません</div>
        <% end %>
      </div>

      <%= link_to new_post_path, class: "absolute bottom-6 right-6 w-16 h-16 bg-[#F2ECD9] rounded-full border-2 border-gray-700 flex items-center justify-center shadow-lg hover:bg-[#e6dfc5] transition active:scale-95" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
        </svg>
      <% end %>

    </div>
  </div>
</div>
