<div class="min-h-screen bg-[#FDFBF7] pt-41 pb-20">
  <%= turbo_frame_tag "main-interface", data: { turbo_action: "advance" } do %>
    
    <div class="w-full" data-controller="notebook-flip">
      <div class="fixed top-0 left-0 w-full z-[10000] bg-[#FDFBF7] shadow-md">
        
        <%# --- A. タイトルエリア (背景色あり) --- %>
        <div class="bg-[#AED7BE] pt-4">
          <div class="flex justify-center items-center mb-2">
            <span class="text-gray-700 font-bold text-lg">プラス日記</span>
          </div>

          <%# --- B. タブ切り替え --- %>
          <div class="flex justify-center w-full px-4">
            <div class="relative w-full max-w-md flex justify-between text-sm font-bold text-gray-700">
              <% active_class = "border-b-4 border-[#FDFBF7]" %>
              <% inactive_class = "text-gray-500 hover:text-gray-700" %>
              
              <%= link_to "世界の良いこと", posts_path(filter: 'public', date: @current_date), 
                  class: "flex-1 text-center pb-2 cursor-pointer transition-colors duration-200 #{params[:filter] != 'friends' ? active_class : inactive_class}" %>

              <%= link_to "フレンドの良いこと", posts_path(filter: 'friends', date: @current_date), 
                  class: "flex-1 text-center pb-2 cursor-pointer transition-colors duration-200 #{params[:filter] == 'friends' ? active_class : inactive_class}" %>
            </div>
          </div>
        </div>

        <%# --- C. カレンダーエリア (ヘッダーの下に結合) --- %>
        <div class="bg-[#F2F0E9] pt-2 pb-0 border-b border-gray-200">
          <div class="flex items-center justify-center space-x-1 px-2 overflow-x-auto whitespace-nowrap scrollbar-hide">
            
            <%# 前の週へ %>
            <%= link_to posts_path(date: @start_date - 1.week, filter: params[:filter]), class: "text-gray-400 hover:text-gray-600 px-2 py-2" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
            <% end %>

            <%# 日付ループ %>
            <% (@start_date..@start_date + 6.days).each do |day| %>
              <% is_active = day == @current_date %>
              <%= link_to posts_path(date: day, filter: params[:filter]), 
                  class: "flex flex-col items-center justify-center w-10 h-14 rounded-full flex-shrink-0 cursor-pointer transition-all duration-200 #{is_active ? 'text-[#AED7BE]' : 'text-gray-600 hover:bg-gray-100'}",
                  data: { action: "click->notebook-flip#flip" } do %>
                  
                <span class="text-xs font-bold mb-1"><%= %w(日 月 火 水 木 金 土)[day.wday] %></span>
                <span class="text-lg font-bold <%= is_active ? 'scale-125' : '' %>"><%= day.day %></span>
                
                <% if is_active %>
                  <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-b-[8px] border-b-[#AED7BE] mt-1"></div>
                <% else %>
                  <div class="h-[9px] w-1"></div>
                <% end %>
              <% end %>
            <% end %>

            <%# 次の週へ %>
            <%= link_to posts_path(date: @start_date + 1.week, filter: params[:filter]), class: "text-gray-400 hover:text-gray-600 px-2 py-2" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            <% end %>
          </div>
        </div>
      </div>

      <%# --- ノートエリア --- %>
      <div class="px-2 max-w-lg mx-auto relative perspective-1000">
        <div id="notebook-page" class="bg-white rounded-r-lg shadow-lg min-h-[428px] flex relative notebook-grid notebook-page-transition">
          
          <%# リング部分 %>
          <div class="w-12 flex-shrink-0 relative border-r border-gray-200">
            <div class="flex flex-col items-center space-y-6 pt-8 h-full">
              <% 9.times do %>
                <div class="relative w-full flex justify-center">
                  <div class="w-4 h-4 bg-gray-300 rounded-full shadow-inner"></div>
                  <div class="absolute -left-3 top-1 w-8 h-2 bg-gray-400 rounded-full border border-gray-500 transform -rotate-12 shadow-md z-10"></div>
                </div>
              <% end %>
            </div>
          </div>

          <%# 投稿リストエリア %>
          <div class="flex-grow p-4 pt-8">
            <% if @posts.present? %>
              <div class="flex flex-col space-y-4">
                <%= render @posts %>
              </div>
            <% else %>
              <div class="flex flex-col items-center justify-center h-64 text-gray-400">
                <p class="text-lg mb-2 font-medium">記録がありません</p>
                <p class="text-sm"><%= @current_date.strftime('%-m月%-d日') %></p>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <%# --- 書くボタン (Frame内に入れて日付情報を保持させる) --- %>
      <%= link_to new_post_path, 
        class: "fixed bottom-20 right-6 w-16 h-16 bg-[#F2ECD9] rounded-full border-2 border-gray-700 flex items-center justify-center shadow-lg hover:bg-[#e6dfc5] transition active:scale-95 z-[10001]", 
        data: { turbo_frame: "_top" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
        </svg>
      <% end %>

    </div>
  <% end %> <%# --- Turbo Frame End --- %>
</div>