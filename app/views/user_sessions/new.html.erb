<div class="container mx-auto px-4">
  <div class="flex justify-center">
    <div class="w-full max-w-2xl mt-16">
      <h1 class="text-3xl font-bold mb-8">ログイン</h1>
      
      <%= form_with url: login_path, data: { turbo: false }, class: "space-y-6" do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 border p-2" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 border p-2" %>
        </div>

        <%= f.submit "ログイン", class: "!no-underline w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-[#008db7] hover:bg-[#00769a] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer transition duration-150" %>
      <% end %>
      <div class="my-8 text-center flex flex-col space-y-2">
        <%= link_to '新規登録はこちら', new_user_path, class: "text-blue-600 hover:underline text-sm" %>
      </div>
    </div>
  </div>
</div>